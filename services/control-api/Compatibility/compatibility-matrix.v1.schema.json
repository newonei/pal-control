{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pal-control.example/schemas/compatibility-matrix.v1.schema.json",
  "title": "PalControl compatibility matrix v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "matrixVersion",
    "generatedAt",
    "canonicalSha256",
    "combinations"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "matrixVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "canonicalSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "combinations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/combination" }
    }
  },
  "$defs": {
    "combination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "gameVersion",
        "steamBuild",
        "palDefenderVersion",
        "ue4ssCommit",
        "nativeProtocolVersion",
        "nativeModVersion",
        "bridgeAvailability",
        "capabilities",
        "status",
        "verifiedAt",
        "evidence",
        "notes"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{2,95}$" },
        "gameVersion": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "steamBuild": { "type": "string", "pattern": "^(unknown|[0-9]{6,12})$" },
        "palDefenderVersion": { "type": "string" },
        "ue4ssCommit": { "type": "string", "pattern": "^(unknown|[a-f0-9]{40})$" },
        "nativeProtocolVersion": { "type": "string" },
        "nativeModVersion": { "type": "string" },
        "bridgeAvailability": { "enum": ["available", "unavailable", "unknown"] },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{1,95}$" }
        },
        "status": { "enum": ["stable", "experimental", "quarantined"] },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "notes": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source", "observedAt", "summary"],
      "properties": {
        "kind": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,31}$" },
        "source": { "type": "string", "minLength": 1, "maxLength": 256 },
        "observedAt": { "type": "string", "format": "date-time" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 512 },
        "artifactSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
