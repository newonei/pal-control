{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pal-control.local/contracts/bridge/message.schema.json",
  "title": "Pal Control Bridge Envelope",
  "oneOf": [
    { "$ref": "#/$defs/hello" },
    { "$ref": "#/$defs/heartbeat" },
    { "$ref": "#/$defs/command" },
    { "$ref": "#/$defs/result" },
    { "$ref": "#/$defs/event" }
  ],
  "$defs": {
    "base": {
      "type": "object",
      "required": ["protocolVersion", "messageType", "messageId", "sentAt"],
      "properties": {
        "protocolVersion": { "const": "1.1" },
        "messageType": { "type": "string" },
        "messageId": { "type": "string", "format": "uuid" },
        "sentAt": { "type": "string", "format": "date-time" }
      }
    },
    "hello": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": [
            "messageType",
            "gameBuild",
            "steamBuild",
            "modVersion",
            "runtimeExecutableSha256",
            "runtimeExecutableSize",
            "runtimeNativeDllSha256",
            "runtimeNativeDllSize",
            "runtimeUe4ssDllSha256",
            "runtimeUe4ssDllSize",
            "runtimeIdentityVerified",
            "writeEnabled",
            "capabilities",
            "probes"
          ],
          "properties": {
            "messageType": { "const": "hello" },
            "gameBuild": {
              "type": "string",
              "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "steamBuild": {
              "type": "string",
              "minLength": 1,
              "maxLength": 32,
              "pattern": "^[0-9]+$"
            },
            "modVersion": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^(?=.*\\S)[^\\u0000-\\u001F\\u007F-\\u009F]+$"
            },
            "runtimeExecutableSha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "runtimeExecutableSize": {
              "type": "integer",
              "minimum": 1
            },
            "runtimeNativeDllSha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "runtimeNativeDllSize": {
              "type": "integer",
              "minimum": 1
            },
            "runtimeUe4ssDllSha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "runtimeUe4ssDllSize": {
              "type": "integer",
              "minimum": 1
            },
            "runtimeIdentityVerified": { "const": true },
            "writeEnabled": { "type": "boolean" },
            "capabilities": {
              "type": "array",
              "minItems": 1,
              "maxItems": 128,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^(?=.*\\S)[^\\u0000-\\u001F\\u007F-\\u009F]+$"
              },
              "uniqueItems": true
            },
            "probes": {
              "type": "object",
              "required": [
                "runtime.executable.sha256",
                "runtime.native_dll.sha256",
                "runtime.ue4ss_dll.sha256",
                "runtime.write_enabled"
              ],
              "minProperties": 1,
              "maxProperties": 128,
              "propertyNames": {
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^(?=.*\\S)[^\\u0000-\\u001F\\u007F-\\u009F]+$"
              },
              "properties": {
                "runtime.executable.sha256": { "const": true },
                "runtime.native_dll.sha256": { "const": true },
                "runtime.ue4ss_dll.sha256": { "const": true },
                "runtime.write_enabled": { "type": "boolean" }
              },
              "additionalProperties": { "type": "boolean" }
            }
          }
        },
        {
          "if": {
            "properties": { "writeEnabled": { "const": false } },
            "required": ["writeEnabled"]
          },
          "then": {
            "properties": {
              "capabilities": {
                "not": {
                  "contains": {
                    "enum": [
                      "players.progression.mutate",
                      "players.progression.write",
                      "inventory.mutate",
                      "inventory.write",
                      "inventory.consume",
                      "inventory.consume.experimental",
                      "pals.mutate",
                      "pals.write",
                      "announcements.overlay.write",
                      "announcements.banner.write",
                      "ui.notifications.write"
                    ]
                  }
                }
              },
              "probes": {
                "properties": {
                  "runtime.write_enabled": { "const": false }
                }
              }
            }
          },
          "else": {
            "properties": {
              "probes": {
                "properties": {
                  "runtime.write_enabled": { "const": true }
                }
              }
            }
          }
        }
      ]
    },
    "heartbeat": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["messageType"],
          "properties": {
            "messageType": { "const": "heartbeat" }
          }
        }
      ]
    },
    "command": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": [
            "messageType",
            "commandId",
            "idempotencyKey",
            "requestHash",
            "serverId",
            "actorId",
            "operation",
            "deadline",
            "expectedRevision",
            "reason",
            "payload"
          ],
          "properties": {
            "messageType": { "const": "command" },
            "commandId": { "type": "string", "format": "uuid" },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 128 },
            "requestHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "serverId": { "type": "string" },
            "actorId": { "type": "string" },
            "operation": { "type": "string" },
            "deadline": { "type": "string", "format": "date-time" },
            "expectedRevision": { "type": "integer", "minimum": 0 },
            "reason": { "type": "string", "minLength": 3, "maxLength": 500 },
            "payload": { "type": "object" }
          }
        },
        {
          "if": {
            "properties": { "operation": { "const": "inventory.consume" } },
            "required": ["operation"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/inventoryConsumePayload" }
            }
          }
        }
      ]
    },
    "inventoryConsumePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshotVersion", "ownerPlayerId", "items", "expectedContainers"],
      "properties": {
        "snapshotVersion": { "const": 1 },
        "ownerPlayerId": {
          "anyOf": [
            { "type": "string", "format": "uuid" },
            { "type": "string", "pattern": "^[A-Fa-f0-9]{32}$" }
          ]
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/inventoryConsumeItem" }
        },
        "expectedContainers": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/inventoryExpectedContainer" }
        }
      }
    },
    "inventoryConsumeItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["itemId", "quantity"],
      "properties": {
        "itemId": {
          "type": "string",
          "pattern": "^(?!None$)[A-Za-z0-9_-]{1,128}$"
        },
        "quantity": { "type": "integer", "minimum": 1, "maximum": 999999 }
      }
    },
    "inventoryExpectedContainer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["containerKind", "containerId", "slots"],
      "properties": {
        "containerKind": { "enum": ["common", "dropSlot", "food"] },
        "containerId": {
          "anyOf": [
            { "type": "string", "format": "uuid" },
            { "type": "string", "pattern": "^[A-Fa-f0-9]{32}$" }
          ]
        },
        "slots": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/inventoryExpectedSlot" }
        }
      }
    },
    "inventoryExpectedSlot": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "slotIndex",
            "itemId",
            "quantity",
            "dynamicCreatedWorldId",
            "dynamicLocalIdInCreatedWorld",
            "hasDynamicItemData",
            "corruptionProgress",
            "corruptionProgressBits"
          ],
          "properties": {
            "slotIndex": { "type": "integer", "minimum": 0 },
            "itemId": { "const": "None" },
            "quantity": { "const": 0 },
            "dynamicCreatedWorldId": { "$ref": "#/$defs/completeGuid" },
            "dynamicLocalIdInCreatedWorld": { "$ref": "#/$defs/completeGuid" },
            "hasDynamicItemData": { "type": "boolean" },
            "corruptionProgress": { "type": "number" },
            "corruptionProgressBits": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4294967295
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "slotIndex",
            "itemId",
            "quantity",
            "dynamicCreatedWorldId",
            "dynamicLocalIdInCreatedWorld",
            "hasDynamicItemData",
            "corruptionProgress",
            "corruptionProgressBits"
          ],
          "properties": {
            "slotIndex": { "type": "integer", "minimum": 0 },
            "itemId": {
              "type": "string",
              "pattern": "^(?!None$)[A-Za-z0-9_-]{1,128}$"
            },
            "quantity": { "type": "integer", "minimum": 1, "maximum": 999999 },
            "dynamicCreatedWorldId": { "$ref": "#/$defs/completeGuid" },
            "dynamicLocalIdInCreatedWorld": { "$ref": "#/$defs/completeGuid" },
            "hasDynamicItemData": { "type": "boolean" },
            "corruptionProgress": { "type": "number" },
            "corruptionProgressBits": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4294967295
            }
          }
        }
      ]
    },
    "completeGuid": {
      "anyOf": [
        { "type": "string", "format": "uuid" },
        { "type": "string", "pattern": "^[A-Fa-f0-9]{32}$" }
      ]
    },
    "result": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["messageType", "commandId", "state", "observedRevision"],
          "properties": {
            "messageType": { "const": "result" },
            "commandId": { "type": "string", "format": "uuid" },
            "state": { "enum": ["succeeded", "failed", "uncertain"] },
            "observedRevision": { "type": "integer", "minimum": 0 },
            "data": { "type": ["object", "null"] },
            "error": {
              "type": ["object", "null"],
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" }
              },
              "required": ["code", "message"]
            }
          }
        }
      ]
    },
    "event": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["messageType", "sequence", "eventType", "payload"],
          "properties": {
            "messageType": { "const": "event" },
            "sequence": { "type": "integer", "minimum": 0 },
            "eventType": { "type": "string" },
            "payload": { "type": "object" }
          }
        }
      ]
    }
  }
}
