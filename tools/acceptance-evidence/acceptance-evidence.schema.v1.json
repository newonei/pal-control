{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/newonei/pal-control/schemas/acceptance-evidence/v1",
  "x-pal-control-schema-version": "1.0.0",
  "title": "PalControl external acceptance evidence manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "schemaSha256",
    "manifestId",
    "gateId",
    "gateCatalogVersion",
    "gateCatalogSha256",
    "evidenceMode",
    "environment",
    "versionCombination",
    "runbook",
    "execution",
    "participants",
    "artifacts",
    "checks",
    "metrics",
    "sensitiveDataScan",
    "review",
    "relatedEvidence",
    "conclusion",
    "signatures"
  ],
  "properties": {
    "$schema": {
      "const": "https://github.com/newonei/pal-control/schemas/acceptance-evidence/v1"
    },
    "schemaVersion": { "const": "1.0.0" },
    "schemaSha256": { "$ref": "#/$defs/sha256" },
    "manifestId": { "type": "string", "pattern": "^ae-[a-z0-9][a-z0-9-]{7,95}$" },
    "gateId": { "$ref": "#/$defs/id" },
    "gateCatalogVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "gateCatalogSha256": { "$ref": "#/$defs/sha256" },
    "evidenceMode": { "enum": ["live", "template"] },
    "environment": { "$ref": "#/$defs/environment" },
    "versionCombination": { "$ref": "#/$defs/versionCombination" },
    "runbook": { "$ref": "#/$defs/runbook" },
    "execution": { "$ref": "#/$defs/execution" },
    "participants": {
      "type": "array",
      "items": { "$ref": "#/$defs/subject" }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "sensitiveDataScan": { "$ref": "#/$defs/sensitiveDataScan" },
    "review": { "$ref": "#/$defs/review" },
    "relatedEvidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/relatedEvidence" }
    },
    "conclusion": { "$ref": "#/$defs/conclusion" },
    "signatures": { "$ref": "#/$defs/signatures" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]{2,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "concreteVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\u0000-\\u001F\\u007F]{1,256}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "artifactIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectId", "identityProvider", "role", "implementationContributor"],
      "properties": {
        "subjectId": {
          "type": "string",
          "pattern": "^subj:hmac-sha256:[a-f0-9]{64}$"
        },
        "identityProvider": { "$ref": "#/$defs/id" },
        "role": { "$ref": "#/$defs/id" },
        "implementationContributor": { "type": "boolean" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environmentId",
        "kind",
        "isSynthetic",
        "dataClassification",
        "serverIdentityHash",
        "worldIdentityHash"
      ],
      "properties": {
        "environmentId": { "$ref": "#/$defs/id" },
        "kind": {
          "enum": ["production", "controlled-live", "fresh-windows-vm", "multi-node-production"]
        },
        "isSynthetic": { "type": "boolean" },
        "dataClassification": { "enum": ["redacted"] },
        "serverIdentityHash": { "$ref": "#/$defs/sha256" },
        "worldIdentityHash": { "$ref": "#/$defs/sha256" }
      }
    },
    "versionCombination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "combinationId",
        "palworldVersion",
        "steamBuild",
        "ue4ssVersion",
        "nativeBridgeVersion",
        "nativeCapability",
        "palDefenderVersion",
        "caddyVersion",
        "controlApiCommit",
        "deploymentPackageSha256",
        "configurationSha256"
      ],
      "properties": {
        "combinationId": {
          "type": "string",
          "pattern": "^combo-sha256:[a-f0-9]{64}$"
        },
        "palworldVersion": { "$ref": "#/$defs/concreteVersion" },
        "steamBuild": { "$ref": "#/$defs/concreteVersion" },
        "ue4ssVersion": { "$ref": "#/$defs/concreteVersion" },
        "nativeBridgeVersion": { "$ref": "#/$defs/concreteVersion" },
        "nativeCapability": { "enum": ["unavailable", "experimental", "stable"] },
        "palDefenderVersion": { "$ref": "#/$defs/concreteVersion" },
        "caddyVersion": { "$ref": "#/$defs/concreteVersion" },
        "controlApiCommit": { "$ref": "#/$defs/commit" },
        "deploymentPackageSha256": { "$ref": "#/$defs/sha256" },
        "configurationSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "runbook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "commit"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "commit": { "$ref": "#/$defs/commit" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor", "startedAt", "endedAt"],
      "properties": {
        "executor": { "$ref": "#/$defs/subject" },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "endedAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "role",
        "mediaType",
        "sha256",
        "sizeBytes",
        "capturedAt",
        "captureMode",
        "producer"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^[^\\\\/][^\\\\]*$"
        },
        "role": { "$ref": "#/$defs/id" },
        "mediaType": { "type": "string", "minLength": 3, "maxLength": 128 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "capturedAt": { "$ref": "#/$defs/timestamp" },
        "captureMode": { "enum": ["live", "template"] },
        "producer": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "result", "artifactIds", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "result": { "enum": ["pending", "pass", "fail"] },
        "artifactIds": { "$ref": "#/$defs/artifactIds" },
        "summary": { "type": "string", "minLength": 8, "maxLength": 2048 }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "value", "unit", "artifactIds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "value": { "type": "number" },
        "unit": { "$ref": "#/$defs/id" },
        "artifactIds": { "$ref": "#/$defs/artifactIds" }
      }
    },
    "sensitiveDataScan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scanner",
        "scannerVersion",
        "command",
        "scope",
        "startedAt",
        "endedAt",
        "result",
        "findingCount",
        "reportArtifactId",
        "scannedArtifactIds"
      ],
      "properties": {
        "scanner": { "type": "string", "minLength": 1, "maxLength": 128 },
        "scannerVersion": { "type": "string", "minLength": 1, "maxLength": 128 },
        "command": { "type": "string", "minLength": 8, "maxLength": 2048 },
        "scope": { "const": "evidence-artifacts" },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "endedAt": { "$ref": "#/$defs/timestamp" },
        "result": { "enum": ["pending", "pass", "fail"] },
        "findingCount": { "type": "integer", "minimum": -1 },
        "reportArtifactId": { "$ref": "#/$defs/id" },
        "scannedArtifactIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "reviewedAt", "decision", "artifactIds", "summary"],
      "properties": {
        "reviewer": { "$ref": "#/$defs/subject" },
        "reviewedAt": { "$ref": "#/$defs/timestamp" },
        "decision": { "enum": ["pending", "approved", "rejected"] },
        "artifactIds": { "$ref": "#/$defs/artifactIds" },
        "summary": { "type": "string", "minLength": 8, "maxLength": 2048 }
      }
    },
    "relatedEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gateId", "manifestPath", "sha256"],
      "properties": {
        "gateId": { "$ref": "#/$defs/id" },
        "manifestPath": { "type": "string", "minLength": 1, "maxLength": 512 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "conclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "decidedAt", "summary"],
      "properties": {
        "result": { "enum": ["pending", "pass", "fail", "not-applicable"] },
        "decidedAt": { "$ref": "#/$defs/timestamp" },
        "summary": { "type": "string", "minLength": 8, "maxLength": 2048 }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "algorithm", "signatureBase64"],
      "properties": {
        "keyId": { "$ref": "#/$defs/id" },
        "algorithm": { "const": "ecdsa-p256-sha256-p1363" },
        "signatureBase64": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "signatures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payloadSchema", "trustStoreSha256", "executor", "reviewer"],
      "properties": {
        "payloadSchema": {
          "const": "https://github.com/newonei/pal-control/schemas/acceptance-signature-payload/v1"
        },
        "trustStoreSha256": { "$ref": "#/$defs/sha256" },
        "executor": { "$ref": "#/$defs/signature" },
        "reviewer": { "$ref": "#/$defs/signature" }
      }
    }
  }
}
