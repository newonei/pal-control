* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf

# Repository text uses LF for deterministic cross-platform diffs.
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.csproj text eol=lf
*.cs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.py text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.lua text eol=lf
*.ini text eol=lf
Caddyfile text eol=lf
*.cmd text eol=crlf
*.iss text eol=crlf

# Binary assets must never be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.dll binary
*.exe binary
*.sav binary
